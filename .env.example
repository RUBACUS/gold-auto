# Copy this file to .env for local development (never commit .env)

# Flask session signing key — generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=replace-with-a-long-random-hex-string

# PostgreSQL connection URL — Railway injects this automatically in production
# For local dev, set this to your local or remote Postgres connection string
DATABASE_URL=postgresql://user:password@localhost:5432/gold_updater

# Login credentials for the two built-in accounts
# If not set, random passwords are generated at startup and printed to logs (dev only)
ADMIN_PASSWORD=change-me-strong-password
VIEWER_PASSWORD=change-me-strong-password

# Set to "production" on Railway to enable HSTS and Secure cookie flags
FLASK_ENV=production
